---
import { t, useTranslations } from '../lib/i18n';
import { assetPath, getLang, localizePath, alternateLang, unbasePath, type Lang } from '../lib/lang';

const { title = 'Awesome Auto Research Hub', description = 'A curated hub for AI systems that automate scientific research: literature review, survey synthesis, experiment design and execution, paper writing, AI scientists, and autonomous research agents.', lang: _lang } = Astro.props;
const lang: Lang = _lang || getLang(Astro.url);
const _t = useTranslations(lang);
const altLang = alternateLang(lang);
const showDatasets = true;
const showProjects = true;
const showResources = true;
const showTrends = true;
const showSurveys = true;

const nav = [
  { href: localizePath('/', lang), label: _t('nav.home') },
  { href: localizePath('/papers', lang), label: _t('nav.papers') },
  showDatasets ? { href: localizePath('/datasets', lang), label: _t('nav.datasets') } : null,
  showProjects ? { href: localizePath('/projects', lang), label: _t('nav.projects') } : null,
  showSurveys ? { href: localizePath('/analysis', lang), label: _t('nav.analysis') } : null,
  showTrends ? { href: localizePath('/trends', lang), label: _t('nav.trends') } : null,
  showResources ? { href: localizePath('/resources', lang), label: _t('nav.resources') } : null,
].filter((item): item is { href: string; label: string } => Boolean(item));
const githubUrl = 'https://github.com/jin-s13/awesome-auto-research-hub';
const altUrl = localizePath(Astro.url.pathname, altLang);
const currentPath = localizePath(unbasePath(Astro.url.pathname), lang);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={assetPath('/favicon.svg')} />
    <link rel="stylesheet" href={assetPath('/styles/global.css')} />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a href={localizePath('/', lang)} class="brand" aria-label="Awesome Auto Research Hub home">
          <span class="brand-mark">⌁</span>
          <span>
            <strong>Awesome Auto Research Hub</strong>
            <small>{_t('brand.subtitle')}</small>
          </span>
        </a>
        <nav class="nav">
          {nav.map((item) => (
            <a class:list={[currentPath === item.href && 'active']} href={item.href}>{item.label}</a>
          ))}
        </nav>
        <div class="header-actions">
          <a class="lang-switcher" href={altUrl}>{altLang === 'en' ? 'English' : '中文'}</a>
          <a class="github-link" href={githubUrl} target="_blank" rel="noreferrer">{_t('nav.github')}</a>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        Built with awesome-hub-generator for AI automated research.
      </footer>
    </div>
  </body>
</html>
